{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@app/*": ["app/*"],
      "@assets/*": ["assets/*"],
      "@components/*": ["components/*"],
      "@hooks/*": ["hooks/*"],
      "@constants/*": ["constants/*"],
      "@services/*": ["services/*"]
    },
    "types": ["expo-router"]
  },
 "include": [
  "app/**/*.ts",
  "app/**/*.tsx",

  "src/**/*.ts",
  "src/**/*.tsx",

  "index.ts",
  "index.tsx",
  "App.tsx",
  ".expo/types/**/*.ts",
  "expo-env.d.ts"
],

 "exclude": [
  "app/debug.tsx"
]

}
